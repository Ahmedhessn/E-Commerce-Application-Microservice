pipeline {
    agent any 

    environment {
        // البيانات الخاصة بالخدمة الحالية
        IMAGE_NAME    = "currencyservice"
        YAML_FILE     = "currencyservice.yaml"
        DOCKER_DIR    = "src/currencyservice"
        
        // البيانات الثابتة (تأكد من الـ Account ID)
        AWS_ACCOUNT_ID = "503459125797"
        GIT_REPO_NAME  = "E-Commerce-Application-Microservice"
        GIT_USER_NAME  = "Ahmedhessn"
        GIT_EMAIL      = "ahmed.hessn1212@gmail.com"
        REPO_URL       = "${AWS_ACCOUNT_ID}.dkr.ecr.us-east-1.amazonaws.com/${IMAGE_NAME}"
        K8S_REPO       = "https://github.com/Ahmedhessn/K8s-CD-files.git"
    }

    stages {
        stage('Cleaning Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'main', url: "https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git"
            }
        }

        stage("Docker Image Build") {
            steps {
                script {
                    dir("${DOCKER_DIR}") {
                        sh "docker build -t ${IMAGE_NAME} ."
                    }
                }
            }
        }

        stage("ECR Image Pushing") {
            steps {
                script {
                    sh """
                    aws ecr get-login-password --region us-east-1 | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.us-east-1.amazonaws.com
                    docker tag ${IMAGE_NAME}:latest ${REPO_URL}:${BUILD_NUMBER}
                    docker push ${REPO_URL}:${BUILD_NUMBER}
                    """
                }
            }
        }

        stage('Update Deployment file') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'my-git-pattoken',
                                                 usernameVariable: 'GIT_USER',
                                                 passwordVariable: 'GIT_PASS')]) {
                    sh '''
                        set -e

                        ASKPASS_PATH="$WORKSPACE/.git-askpass.sh"
                        cat > "$ASKPASS_PATH" <<'EOF'
#!/bin/sh
case "$1" in
  *Username*) echo "$GIT_USER" ;;
  *Password*) echo "$GIT_PASS" ;;
  *) echo ;;
esac
EOF
                        chmod 700 "$ASKPASS_PATH"

                        rm -rf k8s-cd
                        GIT_ASKPASS="$ASKPASS_PATH" GIT_TERMINAL_PROMPT=0 git clone "$K8S_REPO" k8s-cd
                        test -d k8s-cd/kubernetes-files
                        cd k8s-cd/kubernetes-files

                        git config user.email "$GIT_EMAIL"
                        git config user.name "$GIT_USER_NAME"

                        sed -i "s#image:.*#image: $REPO_URL:$BUILD_NUMBER#g" "$YAML_FILE"

                        git add "$YAML_FILE"
                        git commit -m "Update $IMAGE_NAME image to $BUILD_NUMBER" || echo "No changes to commit"

                        git remote set-url origin "https://github.com/Ahmedhessn/K8s-CD-files.git"
                        GIT_ASKPASS="$ASKPASS_PATH" GIT_TERMINAL_PROMPT=0 git push origin HEAD:main
                    '''
                }
            }
        }
    }
}