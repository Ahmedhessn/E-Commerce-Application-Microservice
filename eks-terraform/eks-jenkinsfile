pipeline {
    agent any

    options {
        timestamps()
        // EKS control plane + node group often need 20–45+ minutes; avoid Jenkins aborting early
        timeout(time: 90, unit: 'MINUTES')
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: 'Select the Terraform action to perform'
        )
    }

    stages {
        stage('Checkout from Git') {
            steps {
                // Required if job uses Pipeline script from SCM; re-pulls latest eks-terraform/
                checkout scm
            }
        }

        stage('Terraform version') {
            steps {
                sh 'terraform --version'
            }
        }

        stage('Terraform init') {
            steps {
                dir('eks-terraform') {
                    sh 'terraform init --reconfigure -no-color'
                }
            }
        }

        stage('Terraform validate') {
            steps {
                dir('eks-terraform') {
                    sh 'terraform validate -no-color'
                }
            }
        }

        stage('Terraform plan') {
            steps {
                dir('eks-terraform') {
                    sh 'terraform plan -no-color -out=tfplan'
                }
            }
        }

        stage('Terraform apply') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                dir('eks-terraform') {
                    echo 'EKS: control plane usually ~15–25 min; node group ~5–15 min. Log may look idle — this is normal.'
                    // Stream output; tee keeps console visible in some Jenkins setups
                    sh 'terraform apply -no-color -auto-approve -input=false tfplan 2>&1 | tee terraform-apply.log'
                }
            }
        }

        stage('Terraform destroy') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                dir('eks-terraform') {
                    sh 'terraform destroy -no-color -auto-approve -input=false'
                }
            }
        }
    }
}
